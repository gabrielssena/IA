# =========================================
# NAIVE BAYES + REDE BAYESIANA (EXERCÍCIOS)
# =========================================

import pandas as pd

# =========================================
# 1. DATASET
# =========================================
data = [
['infantil','miopia','não','reduzida','nenhuma'],
['infantil','miopia','sim','normal','gelatinosa'],
['infantil','hipermetropia','não','normal','gelatinosa'],
['infantil','hipermetropia','sim','normal','dura'],

['adolescente','miopia','não','reduzida','gelatinosa'],
['adolescente','miopia','sim','reduzida','nenhuma'],
['adolescente','miopia','não','normal','dura'],
['adolescente','hipermetropia','não','reduzida','gelatinosa'],
['adolescente','hipermetropia','sim','normal','dura'],

['adulto','miopia','não','normal','gelatinosa'],
['adulto','miopia','sim','normal','dura'],
['adulto','miopia','sim','normal','gelatinosa'],
['adulto','hipermetropia','não','reduzida','nenhuma'],
['adulto','hipermetropia','sim','normal','gelatinosa'],
['adulto','hipermetropia','não','normal','gelatinosa'],
]

columns = ['idade','diagnostico','astigmatismo','taxa_lacrimal','classe']
df = pd.DataFrame(data, columns=columns)

# =========================================
# 2. CONFIG
# =========================================
alpha = 1
classes = df['classe'].unique()
features = df.columns[:-1]

# =========================================
# 3. PRIORS (P(C))
# =========================================
class_counts = df['classe'].value_counts()
priors = (class_counts + alpha) / (len(df) + alpha * len(classes))

# =========================================
# 4. PROBABILIDADES CONDICIONAIS (NAIVE)
# =========================================
cond_probs = {}

for feature in features:
    cond_probs[feature] = {}
    values = df[feature].unique()
    
    for c in classes:
        subset = df[df['classe'] == c]
        total = len(subset)
        
        cond_probs[feature][c] = {}
        
        for v in values:
            count = len(subset[subset[feature] == v])
            prob = (count + alpha) / (total + alpha * len(values))
            cond_probs[feature][c][v] = prob

# =========================================
# 5. PACIENTE (EXERCÍCIO 2)
# =========================================
paciente = {
    'idade': 'infantil',
    'diagnostico': 'hipermetropia',
    'astigmatismo': 'não',
    'taxa_lacrimal': 'reduzida'
}

# =========================================
# 6. CLASSIFICAÇÃO NAIVE BAYES
# =========================================
def prever_naive():
    resultados = {}

    for c in classes:
        prob = priors[c]
        
        for feature in features:
            prob *= cond_probs[feature][c][paciente[feature]]
        
        resultados[c] = prob

    total = sum(resultados.values())
    normalizado = {k: v/total for k,v in resultados.items()}
    
    return normalizado

# =========================================
# 7. REDE BAYESIANA (idade -> taxa_lacrimal)
# =========================================
prob_taxa_cond = {}

for c in classes:
    prob_taxa_cond[c] = {}
    
    subset_c = df[df['classe'] == c]
    
    for idade in df['idade'].unique():
        prob_taxa_cond[c][idade] = {}
        
        subset_idade = subset_c[subset_c['idade'] == idade]
        
        for taxa in df['taxa_lacrimal'].unique():
            count = len(subset_idade[subset_idade['taxa_lacrimal'] == taxa])
            
            prob = (count + alpha) / (
                len(subset_idade) + alpha * len(df['taxa_lacrimal'].unique())
            )
            
            prob_taxa_cond[c][idade][taxa] = prob

# =========================================
# 8. CLASSIFICAÇÃO COM REDE BAYESIANA
# =========================================
def prever_rede():
    resultados = {}

    for c in classes:
        prob = priors[c]
        
        # idade
        prob *= cond_probs['idade'][c][paciente['idade']]
        
        # taxa depende da idade
        prob *= prob_taxa_cond[c][paciente['idade']][paciente['taxa_lacrimal']]
        
        # independentes
        prob *= cond_probs['diagnostico'][c][paciente['diagnostico']]
        prob *= cond_probs['astigmatismo'][c][paciente['astigmatismo']]
        
        resultados[c] = prob

    total = sum(resultados.values())
    normalizado = {k: v/total for k,v in resultados.items()}
    
    return normalizado

# =========================================
# 9. EXECUÇÃO
# =========================================
print("=== PRIORS ===")
print(priors, "\n")

print("=== NAIVE BAYES ===")
nb = prever_naive()
for k,v in nb.items():
    print(f"{k}: {v:.4f}")
print("Classe:", max(nb, key=nb.get), "\n")

print("=== REDE BAYESIANA ===")
rb = prever_rede()
for k,v in rb.items():
    print(f"{k}: {v:.4f}")
print("Classe:", max(rb, key=rb.get))
